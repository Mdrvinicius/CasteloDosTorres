<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.castelodostorres.sistema.controlador.ControladorTelaDetalhesFuncionario"
      spacing="15">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>

    <Button text="← Voltar" onAction="#voltar" />

    <Label text="Detalhes do Funcionário" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <GridPane hgap="10" vgap="8">
        <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="campoNome" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Função:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboPapel" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Tipo de Remuneração:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <ComboBox fx:id="comboTipoRemuneracao" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="Valor:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="campoValor" GridPane.rowIndex="3" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="10">
        <Button text="Salvar Alterações" onAction="#salvarAlteracoes" />
    </HBox>

</VBox>