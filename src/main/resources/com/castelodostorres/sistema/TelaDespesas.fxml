<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.castelodostorres.sistema.controlador.ControladorTelaDespesas"
      styleClass="painel-conteudo" spacing="15">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>

    <Label text="Despesas" styleClass="titulo-tela" />

    <!-- BLOCO 1: Formulário de cadastro/edição (card) -->
    <VBox fx:id="cardFormulario" styleClass="card" spacing="10">
        <Label fx:id="labelFormulario" text="Nova Despesa" styleClass="subtitulo" />

        <GridPane hgap="10" vgap="8">
            <Label text="Nome/Razão:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
            <TextField fx:id="campoNome" GridPane.rowIndex="0" GridPane.columnIndex="1" />

            <Label text="Valor (R$):" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
            <TextField fx:id="campoValor" GridPane.rowIndex="1" GridPane.columnIndex="1" />

            <Label text="Tipo:" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
            <ComboBox fx:id="comboTipo" GridPane.rowIndex="2" GridPane.columnIndex="1" />
        </GridPane>

        <HBox spacing="10">
            <Button fx:id="botaoSalvar" text="Salvar" onAction="#salvar" />
            <Button fx:id="botaoCancelarEdicao" text="Cancelar Edição" onAction="#cancelarEdicao" styleClass="botao-secundario" />
        </HBox>
    </VBox>

    <!-- BLOCO 2: Lista de despesas -->
    <Label text="Despesas Cadastradas" styleClass="subtitulo" />
    <Label text="Recorrentes aparecem primeiro. Dê duplo-clique para editar." styleClass="texto-suave" />

    <TableView fx:id="tabelaDespesas" prefHeight="300">
        <columns>
            <TableColumn fx:id="colunaNome" text="Nome/Razão" prefWidth="220" />
            <TableColumn fx:id="colunaTipo" text="Tipo" prefWidth="120" />
            <TableColumn fx:id="colunaValor" text="Valor (R$)" prefWidth="120" />
            <TableColumn fx:id="colunaData" text="Cadastrada em" prefWidth="150" />
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="botaoApagar" text="Apagar Selecionada" onAction="#apagar" styleClass="botao-perigo" />
        <Button fx:id="botaoAjustarMes" text="Ajustar Valor do Mês" onAction="#ajustarValorMes" styleClass="botao-secundario" />
    </HBox>

</VBox>