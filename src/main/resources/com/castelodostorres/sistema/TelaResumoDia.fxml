<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.castelodostorres.sistema.controlador.ControladorTelaResumoDia"
            fitToWidth="true" styleClass="painel-conteudo">

    <VBox spacing="16">
        <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>

        <!-- Cabeçalho -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox spacing="2">
                <Label text="Resumo do Dia" styleClass="titulo-tela" />
                <Label text="Visão geral de todas as atividades e valores do dia selecionado." styleClass="texto-suave" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Data:" styleClass="form-label" />
            <DatePicker fx:id="seletorData" />
            <Button text="Gerar" onAction="#gerar" />
        </HBox>

        <!-- Métricas do topo -->
        <HBox spacing="14">
            <VBox styleClass="card-metrica" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Visitas" styleClass="form-label" />
                <Label fx:id="labelQtdVisitas" text="0" styleClass="metrica-valor" />
            </VBox>
            <VBox styleClass="card-metrica" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Inteiras" styleClass="form-label" />
                <Label fx:id="labelTotalInteiras" text="0" styleClass="metrica-valor" />
            </VBox>
            <VBox styleClass="card-metrica" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Meias" styleClass="form-label" />
                <Label fx:id="labelTotalMeias" text="0" styleClass="metrica-valor" />
            </VBox>
            <VBox styleClass="card-metrica" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Não Pagantes" styleClass="form-label" />
                <Label fx:id="labelTotalNaoPagantes" text="0" styleClass="metrica-valor" />
            </VBox>
            <VBox styleClass="card-metrica-destaque" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Total Arrecadado" styleClass="form-label" />
                <Label fx:id="labelTotal" text="R$ 0,00" styleClass="metrica-valor-verde" />
            </VBox>
        </HBox>

        <!-- Corpo -->
        <HBox spacing="16" alignment="TOP_LEFT">

            <VBox spacing="16" prefWidth="620" HBox.hgrow="ALWAYS" maxWidth="Infinity">

                <!-- formas de pagamento -->
                <VBox styleClass="card" spacing="12">
                    <Label text="Detalhamento por forma de pagamento" styleClass="subtitulo" />
                    <HBox spacing="12">
                        <VBox styleClass="card-interno" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Dinheiro" styleClass="form-label" />
                            <Label fx:id="labelDinheiro" text="R$ 0,00" styleClass="valor-positivo" />
                        </VBox>
                        <VBox styleClass="card-interno" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Pix" styleClass="form-label" />
                            <Label fx:id="labelPix" text="R$ 0,00" styleClass="valor-roxo" />
                        </VBox>
                        <VBox styleClass="card-interno" spacing="4" alignment="CENTER" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Débito" styleClass="form-label" />
                            <Label fx:id="labelDebito" text="R$ 0,00" styleClass="valor-azul" />
                        </VBox>
                    </HBox>
                    <HBox styleClass="faixa-info" spacing="8" alignment="CENTER_LEFT">
                        <Label fx:id="labelAgendadosDia" text="Valor de agendados: —" styleClass="texto-suave" />
                    </HBox>
                </VBox>

                <!-- reembolsos + valor final -->
                <HBox spacing="16">
                    <VBox styleClass="card" spacing="4" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Total de Reembolsos" styleClass="form-label" />
                        <Label fx:id="labelTotalReembolsos" text="R$ 0,00" styleClass="metrica-valor-vermelho" />
                    </VBox>
                    <VBox styleClass="card" spacing="4" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <Label text="Valor Final do Dia" styleClass="form-label" />
                        <Label fx:id="labelValorFinal" text="R$ 0,00" styleClass="metrica-valor-verde" />
                    </VBox>
                </HBox>

            </VBox>

            <!-- comissões -->
            <VBox styleClass="card" spacing="10" prefWidth="500" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Pagamento aos Funcionários" styleClass="subtitulo" />
                <TableView fx:id="tabelaComissao" prefHeight="260">
                    <columns>
                        <TableColumn fx:id="colunaNome" text="Funcionário" prefWidth="200" />
                        <TableColumn fx:id="colunaPapel" text="Função" prefWidth="130" />
                        <TableColumn fx:id="colunaValor" text="A Receber (R$)" prefWidth="120" />
                    </columns>
                </TableView>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Total a Pagar aos Funcionários" styleClass="form-label" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="labelTotalComissao" text="R$ 0,00" styleClass="valor-destaque" />
                </HBox>
            </VBox>

        </HBox>
    </VBox>
</ScrollPane>