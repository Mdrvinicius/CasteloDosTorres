<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.castelodostorres.sistema.controlador.ControladorTelaResumoMes"
      spacing="15">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>

    <Label text="Resumo do Mês" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10">
        <Label text="Mês:" />
        <ComboBox fx:id="comboMes" prefWidth="120" />
        <Label text="Ano:" />
        <TextField fx:id="campoAno" prefWidth="80" />
        <Button text="Gerar" onAction="#gerar" />
    </HBox>

    <Label fx:id="labelArrecadado" text="Valor Total Arrecadado: R$ 0,00" style="-fx-font-size: 15px; -fx-font-weight: bold;" />
    <Label fx:id="labelTotalPago" text="Total Pago aos Funcionários: R$ 0,00" style="-fx-font-size: 15px;" />
    <Label fx:id="labelLiquidoFinal" text="Valor Líquido Final: R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a7a1a;" />

    <Label text="Detalhamento de Pagamentos aos Funcionários:" style="-fx-font-weight: bold;" />

    <TableView fx:id="tabelaComissao" prefHeight="250">
        <columns>
            <TableColumn fx:id="colunaNome" text="Funcionário" prefWidth="220" />
            <TableColumn fx:id="colunaPapel" text="Função" prefWidth="130" />
            <TableColumn fx:id="colunaValor" text="Total Pago no Mês (R$)" prefWidth="160" />
        </columns>
    </TableView>

</VBox>