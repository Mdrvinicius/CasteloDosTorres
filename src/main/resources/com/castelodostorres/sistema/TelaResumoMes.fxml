<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.castelodostorres.sistema.controlador.ControladorTelaResumoMes" >

<VBox spacing="15">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15" />
    </padding>

    <Label text="Resumo do Mês" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10">
        <Label text="Mês:" />
        <ComboBox fx:id="comboMes" prefWidth="120" />
        <Label text="Ano:" />
        <TextField fx:id="campoAno" prefWidth="80" />
        <Button text="Gerar" onAction="#gerar" />
    </HBox>

    <Label fx:id="labelArrecadado" text="Valor Total Arrecadado: R$ 0,00" style="-fx-font-size: 15px; -fx-font-weight: bold;" />

    <Label text="Detalhamento de Pagamentos aos Funcionários:" style="-fx-font-weight: bold;" />

    <TableView fx:id="tabelaComissao" prefHeight="250">
        <columns>
            <TableColumn fx:id="colunaNome" text="Funcionário" prefWidth="220" />
            <TableColumn fx:id="colunaPapel" text="Função" prefWidth="130" />
            <TableColumn fx:id="colunaValor" text="Total Pago no Mês (R$)" prefWidth="160" />
        </columns>
    </TableView>
    <Label fx:id="labelTotalPago" text="Total Pago aos Funcionários: R$ 0,00" style="-fx-font-size: 15px;" />

    <Label text="Detalhamento de Despesas" styleClass="subtitulo" />

    <TableView fx:id="tabelaDespesas" prefHeight="200">
        <columns>
            <TableColumn fx:id="colunaDataDespesa" text="Data" prefWidth="140" />
            <TableColumn fx:id="colunaRazaoDespesa" text="Razão" prefWidth="220" />
            <TableColumn fx:id="colunaTipoDespesa" text="Tipo" prefWidth="120" />
            <TableColumn fx:id="colunaValorDespesa" text="Valor (R$)" prefWidth="120" />
        </columns>
    </TableView>

    <Label fx:id="labelTotalDespesas" text="Total de Despesas: R$ 0,00" styleClass="valor-negativo" />

    <Label fx:id="labelLiquidoFinal" text="Valor Líquido Final: R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a7a1a;" />
    <Label text="Fechamentos de Caixa do Mês" styleClass="subtitulo" />

    <TableView fx:id="tabelaFechamentos" prefHeight="250">
        <columns>
            <TableColumn fx:id="colFechData" text="Data" prefWidth="100" />
            <TableColumn fx:id="colFechFunc" text="Fechou" prefWidth="130" />
            <TableColumn fx:id="colFechDinEsp" text="Dinh. Esperado" prefWidth="110" />
            <TableColumn fx:id="colFechDinCont" text="Dinh. Contado" prefWidth="110" />
            <TableColumn fx:id="colFechDinDiv" text="Div. Dinheiro" prefWidth="110" />
            <TableColumn fx:id="colFechPixEsp" text="Pix+Déb Esperado" prefWidth="120" />
            <TableColumn fx:id="colFechPixCont" text="Pix+Déb Contado" prefWidth="120" />
            <TableColumn fx:id="colFechPixDiv" text="Div. Pix+Déb" prefWidth="110" />
            <TableColumn fx:id="colFechStatus" text="Status" prefWidth="90" />
        </columns>
    </TableView>

</VBox>
</ScrollPane>
