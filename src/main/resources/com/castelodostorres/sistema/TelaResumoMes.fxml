<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.castelodostorres.sistema.controlador.ControladorTelaResumoMes"
            fitToWidth="true" styleClass="painel-conteudo">

    <VBox spacing="16">
        <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>

        <!-- Cabeçalho -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox spacing="2">
                <Label text="Resumo do Mês" styleClass="titulo-tela" />
                <Label text="Visão geral consolidada do mês selecionado." styleClass="texto-suave" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Mês:" styleClass="form-label" />
            <ComboBox fx:id="comboMes" prefWidth="120" />
            <Label text="Ano:" styleClass="form-label" />
            <TextField fx:id="campoAno" prefWidth="80" />
            <Button text="Gerar" onAction="#gerar" />
        </HBox>

        <HBox spacing="16" alignment="TOP_LEFT">

            <!-- Coluna esquerda -->
            <VBox spacing="16" prefWidth="900" HBox.hgrow="ALWAYS" maxWidth="Infinity">

                <VBox styleClass="card-metrica-destaque" spacing="4">
                    <Label text="Valor Total Arrecadado" styleClass="form-label" />
                    <Label fx:id="labelArrecadadoTopo" text="R$ 0,00" styleClass="metrica-valor-verde" />
                </VBox>

                <VBox styleClass="card" spacing="10">
                    <Label text="Detalhamento de Pagamentos aos Funcionários" styleClass="subtitulo" />
                    <TableView fx:id="tabelaComissao" prefHeight="250">
                        <columns>
                            <TableColumn fx:id="colunaNome" text="Funcionário" prefWidth="220" />
                            <TableColumn fx:id="colunaPapel" text="Função" prefWidth="130" />
                            <TableColumn fx:id="colunaValor" text="Total Pago no Mês (R$)" prefWidth="160" />
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Total Pago aos Funcionários" styleClass="form-label" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="labelTotalPagoTabela" text="R$ 0,00" styleClass="valor-destaque" />
                    </HBox>
                </VBox>

                <VBox styleClass="card" spacing="10">
                    <Label text="Detalhamento de Despesas" styleClass="subtitulo" />
                    <TableView fx:id="tabelaDespesas" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="colunaDataDespesa" text="Data" prefWidth="140" />
                            <TableColumn fx:id="colunaRazaoDespesa" text="Razão" prefWidth="220" />
                            <TableColumn fx:id="colunaTipoDespesa" text="Tipo" prefWidth="120" />
                            <TableColumn fx:id="colunaValorDespesa" text="Valor (R$)" prefWidth="120" />
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Total de Despesas" styleClass="form-label" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="labelTotalDespesasTabela" text="R$ 0,00" styleClass="valor-negativo" />
                    </HBox>
                </VBox>

                <VBox styleClass="card" spacing="10">
                    <Label text="Fechamentos de Caixa do Mês" styleClass="subtitulo" />
                    <TableView fx:id="tabelaFechamentos" prefHeight="250">
                        <columns>
                            <TableColumn fx:id="colFechData" text="Data" prefWidth="100" />
                            <TableColumn fx:id="colFechFunc" text="Fechou" prefWidth="130" />
                            <TableColumn fx:id="colFechDinEsp" text="Dinh. Esperado" prefWidth="110" />
                            <TableColumn fx:id="colFechDinCont" text="Dinh. Contado" prefWidth="110" />
                            <TableColumn fx:id="colFechDinDiv" text="Div. Dinheiro" prefWidth="110" />
                            <TableColumn fx:id="colFechPixEsp" text="Pix+Déb Esperado" prefWidth="120" />
                            <TableColumn fx:id="colFechPixCont" text="Pix+Déb Contado" prefWidth="120" />
                            <TableColumn fx:id="colFechPixDiv" text="Div. Pix+Déb" prefWidth="110" />
                            <TableColumn fx:id="colFechStatus" text="Status" prefWidth="90" />
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <!-- Coluna direita: cards de resumo -->
            <VBox spacing="14" prefWidth="280">
                <VBox styleClass="card-metrica-destaque" spacing="4">
                    <Label text="Valor Total Arrecadado" styleClass="form-label" />
                    <Label fx:id="labelArrecadado" text="R$ 0,00" styleClass="metrica-valor-verde" />
                </VBox>
                <VBox styleClass="card-metrica-azul" spacing="4">
                    <Label text="Total Pago aos Funcionários" styleClass="form-label" />
                    <Label fx:id="labelTotalPago" text="R$ 0,00" styleClass="metrica-valor-azul" />
                </VBox>
                <VBox styleClass="card-metrica-vermelho" spacing="4">
                    <Label text="Total de Despesas" styleClass="form-label" />
                    <Label fx:id="labelTotalDespesas" text="R$ 0,00" styleClass="metrica-valor-vermelho" />
                </VBox>
                <VBox styleClass="card-metrica-destaque" spacing="4">
                    <Label text="Valor Líquido Final" styleClass="form-label" />
                    <Label fx:id="labelLiquidoFinal" text="R$ 0,00" styleClass="metrica-valor-verde" />
                </VBox>
            </VBox>

        </HBox>
    </VBox>
</ScrollPane>